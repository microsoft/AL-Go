    "branches": [ "main" ],
    "environmentName": "Internal-Master",
    "ContinuousDeployment": true,
    "runs-on": "[ self-hosted, windows ]"
  },
  "DeployToInternal-Staging": {
    "branches": [ "staging" ],
    "environmentName": "Internal-Staging",
    "ContinuousDeployment": true,
    "runs-on": "[ self-hosted, windows ]"
  },
